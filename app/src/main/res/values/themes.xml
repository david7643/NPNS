<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.NSND" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- 배경 -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>

        <!-- 포인트 컬러 -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_secondary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_light</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- 텍스트 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- 상태바 / 네비게이션바 -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

    </style>

    <style name="Theme.NSND" parent="Base.Theme.NSND" />

    <!-- 경보 오버레이 전용 테마 -->
    <style name="Theme.NSND.Alert" parent="Base.Theme.NSND">
        <item name="android:windowBackground">@color/alert_red</item>
        <item name="android:statusBarColor">@color/alert_red</item>
        <item name="android:navigationBarColor">@color/alert_red</item>
    </style>

    <!-- 테마 선택 칩 버튼 스타일 -->
    <style name="Widget.NSND.ThemeChip" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- 기본 버튼 둥근 모서리 스타일 -->
    <style name="Widget.NSND.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.NSND.Button</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ShapeAppearance.NSND.Button" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">12dp</item>
    </style>

</resources>